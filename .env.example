# Anthropic / Claude
ANTHROPIC_API_KEY=

# bunq — prefix with sandbox_ to auto-route to sandbox
BUNQ_API_KEY=

# AWS (Transcribe + Bedrock Nova Lite + S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=           # Only needed for temporary / STS credentials
AWS_DEFAULT_REGION=us-east-1

# Google Maps (place search for recommendations)
GOOGLE_MAPS_API_KEY=

# Ticketmaster (event discovery)
TICKETMASTER_API_KEY=

# Mastercard Exchange Rates API (optional — falls back to ECB rates)
# Register at https://developer.mastercard.com, download your .p12, then export the private key:
#   openssl pkcs12 -in yourkey.p12 -nocerts -nodes -out private.pem
MASTERCARD_CONSUMER_KEY=
MASTERCARD_PRIVATE_KEY_PATH=

# Wise Platform API (optional — falls back to ECB rates)
# Create an API token at https://wise.com/settings/api-tokens
WISE_API_KEY=
